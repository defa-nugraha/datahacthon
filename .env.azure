APP_NAME="Vera AI"
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=http://localhost:8080
APP_PORT=8080

PHP_VERSION=8.4
NODE_MAJOR=22
COMPOSER_VERSION=2.8

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite
RUN_MIGRATIONS=true
RUN_SEEDERS=true
ALLOW_DEMO_SEEDING_IN_PRODUCTION=true
RUN_SCHEDULER=true

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database
LOG_CHANNEL=stderr

AI_ADVISOR_BASE_URL=http://fastapi:8001
AI_ADVISOR_TIMEOUT=20
AI_SERVICE_PORT=8001

AI_ADVISOR_THRESHOLD_ENABLED=true
AI_ADVISOR_THRESHOLD_MIN_HISTORY_POINTS=2
AI_ADVISOR_MIN_INTERVAL_MINUTES=60
AI_ADVISOR_THRESHOLD_PH_DELTA=0.25
AI_ADVISOR_THRESHOLD_N_DELTA=8
AI_ADVISOR_THRESHOLD_P_DELTA=5
AI_ADVISOR_THRESHOLD_K_DELTA=8
AI_ADVISOR_THRESHOLD_MOISTURE_DELTA=8
AI_ADVISOR_CRITICAL_PH_LOW=5.8
AI_ADVISOR_CRITICAL_PH_HIGH=7.5
AI_ADVISOR_CRITICAL_P_LOW=18
AI_ADVISOR_CRITICAL_MOISTURE_LOW=25

AZURE_OPENAI_ENABLED=false
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_USE_ENTRA_ID=false
AZURE_OPENAI_TEMPERATURE=0.2
AZURE_OPENAI_MAX_OUTPUT_TOKENS=900

AZURE_LARAVEL_IMAGE=verai-laravel:azure
AZURE_FASTAPI_IMAGE=verai-fastapi:azure
